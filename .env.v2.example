# =============================================================================
# OSIRIS-Lab v2 — Environment Configuration
# =============================================================================
# This file contains all configuration variables for the OSIRIS-Lab v2 platform.
# 
# USAGE:
#   1. Copy this file to .env.v2
#   2. Generate secrets using: ./scripts/generate-secrets.sh
#   3. Customize values for your environment
#   4. Never commit .env.v2 to version control
# =============================================================================

# ─── CORE IDENTITY ───────────────────────────────────────────────────────────
NODE_ENV=production
GITHUB_SHA=latest

# ─── NETWORKING ──────────────────────────────────────────────────────────────
# Host ports (change if conflicts exist)
OSIRIS_API_GATEWAY_PORT=8000
OSIRIS_API_GATEWAY_SSL_PORT=8443
GRAFANA_PORT=3001

# Internal service ports (do not change)
NATS_PORT=4222
NATS_MONITOR_PORT=8222
POSTGRES_PORT=5432
NEO4J_PORT=7687
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
ELASTICSEARCH_PORT=9200
TEMPO_PORT=3200
PROMETHEUS_PORT=9090
LOKI_PORT=3100

# ─── DATABASE CREDENTIALS ────────────────────────────────────────────────────
# These are reference names only — actual passwords in .secrets/
POSTGRES_USER=osiris
POSTGRES_DB=osiris
NEO4J_USER=neo4j

# ─── CACHE CREDENTIALS ───────────────────────────────────────────────────────
# Redis password in .secrets/redis_password.txt

# ─── OBJECT STORAGE ──────────────────────────────────────────────────────────
MINIO_ROOT_USER=osiris
# MinIO password in .secrets/minio_root_password.txt

# ─── MESSAGE BUS ─────────────────────────────────────────────────────────────
NATS_USER=osiris
# NATS password in .secrets/nats_password.txt

# ─── SECURITY ────────────────────────────────────────────────────────────────
# JWT secret in .secrets/jwt_secret.txt (min 32 bytes)
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption key in .secrets/encryption_key.txt (32 bytes)
ENCRYPTION_ALGORITHM=AES-256-GCM

# ─── OBSERVABILITY ───────────────────────────────────────────────────────────
# Grafana admin password in .secrets/grafana_password.txt
GRAFANA_ADMIN_PASSWORD=admin

# Log retention
LOKI_RETENTION_DAYS=30
PROMETHEUS_RETENTION_DAYS=90
TEMPO_RETENTION_DAYS=7

# ─── SERVICE RESOURCES ───────────────────────────────────────────────────────
# API Gateway
API_GATEWAY_MEMORY_LIMIT=512M
API_GATEWAY_CPU_LIMIT=0.5

# BFF
BFF_MEMORY_LIMIT=512M
BFF_CPU_LIMIT=0.5

# AI Engine
AI_ENGINE_MEMORY_LIMIT=2G
AI_ENGINE_CPU_LIMIT=1.0

# Graph Engine (Neo4j)
NEO4J_MEMORY_LIMIT=4G
NEO4J_CPU_LIMIT=2.0
NEO4J_HEAP_SIZE=2G

# Search Engine
QDRANT_MEMORY_LIMIT=2G
QDRANT_CPU_LIMIT=1.0
ELASTICSEARCH_MEMORY_LIMIT=4G
ELASTICSEARCH_CPU_LIMIT=2.0

# IOC Engine
IOC_ENGINE_MEMORY_LIMIT=512M
IOC_ENGINE_CPU_LIMIT=0.5

# GEOINT Engine
GEOINT_MEMORY_LIMIT=1G
GEOINT_CPU_LIMIT=0.5

# Workflow Engine (Temporal)
TEMPORAL_MEMORY_LIMIT=1G
TEMPORAL_CPU_LIMIT=0.5

# Plugin Engine
PLUGIN_ENGINE_MEMORY_LIMIT=512M
PLUGIN_ENGINE_CPU_LIMIT=0.5

# Ingestion API
INGESTION_MEMORY_LIMIT=512M
INGESTION_CPU_LIMIT=0.5

# Normalization
NORMALIZATION_MEMORY_LIMIT=512M
NORMALIZATION_CPU_LIMIT=0.5

# Event Bus (NATS)
NATS_MEMORY_LIMIT=512M
NATS_CPU_LIMIT=0.5

# Databases
POSTGRES_MEMORY_LIMIT=2G
POSTGRES_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=2G
REDIS_CPU_LIMIT=0.5

# Object Storage
MINIO_MEMORY_LIMIT=1G
MINIO_CPU_LIMIT=0.5

# Observability
ALLOY_MEMORY_LIMIT=512M
ALLOY_CPU_LIMIT=0.5
LOKI_MEMORY_LIMIT=512M
LOKI_CPU_LIMIT=0.5
PROMETHEUS_MEMORY_LIMIT=1G
PROMETHEUS_CPU_LIMIT=0.5
TEMPO_MEMORY_LIMIT=512M
TEMPO_CPU_LIMIT=0.5
GRAFANA_MEMORY_LIMIT=256M
GRAFANA_CPU_LIMIT=0.25

# ─── SCALING ─────────────────────────────────────────────────────────────────
# Number of replicas for each service (1 = single instance)
API_GATEWAY_REPLICAS=3
BFF_REPLICAS=3
AI_ENGINE_REPLICAS=5
IOC_ENGINE_REPLICAS=3
GEOINT_REPLICAS=3
PLUGIN_ENGINE_REPLICAS=2
INGESTION_REPLICAS=3
NORMALIZATION_REPLICAS=2

# ─── FEATURE FLAGS ───────────────────────────────────────────────────────────
ENABLE_PLUGIN_SYSTEM=true
ENABLE_WORKFLOW_ENGINE=true
ENABLE_AI_ANALYSIS=true
ENABLE_REALTIME_SUBSCRIPTIONS=true
ENABLE_AUDIT_LOGGING=true

# ─── EXTERNAL INTEGRATIONS ───────────────────────────────────────────────────
# OSINT API keys (add as needed)
# FIRMS_API_KEY=
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=
# N2YO_API_KEY=
# AIS_API_KEY=

# ─── MONITORING ─────────────────────────────────────────────────────────────
# Alert webhook URLs (Slack, PagerDuty, etc.)
# SLACK_WEBHOOK_URL=
# PAGERDUTY_INTEGRATION_KEY=

# Health check intervals (seconds)
HEALTHCHECK_INTERVAL=30
HEALTHCHECK_TIMEOUT=10
HEALTHCHECK_RETRIES=3

# ─── BACKUP ──────────────────────────────────────────────────────────────────
# Backup configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backup/osiris

# ─── DEVELOPMENT ─────────────────────────────────────────────────────────────
# Enable debug mode (adds verbose logging)
# DEBUG=false

# Enable hot reload for development
# HOT_RELOAD=false

# Skip authentication in development
# SKIP_AUTH=false