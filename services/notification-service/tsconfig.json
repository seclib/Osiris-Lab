{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@osiris/nats-client": ["../../libs/events/src/index.ts"],
      "@osiris/logger": ["../../libs/shared/src/index.ts"],
      "@osiris/metrics": ["../../libs/shared/src/index.ts"]
    },
    "types": ["node", "jest", "express", "pg", "redis", "vitest"]
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
