{
  "name": "@osiris/workflow-designer-service",
  "version": "1.0.0",
  "description": "Workflow Designer Service — DAG-based workflow management",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "migrate": "node-pg-migrate up --envPath .env",
    "migrate:down": "node-pg-migrate down --envPath .env"
  },
  "dependencies": {
    "@osiris/nats-client": "^1.0.0",
    "@osiris/logger": "^1.0.0",
    "@osiris/metrics": "^1.0.0",
    "@osiris/events": "^1.0.0",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "node-pg-migrate": "^7.0.0"
  }
}