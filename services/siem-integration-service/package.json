{
  "name": "@osiris/siem-integration-service",
  "version": "1.0.0",
  "description": "SIEM integration service with bidirectional connectors for Splunk, QRadar, ELK, Sentinel",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "migrate": "psql $DATABASE_URL -f migrations/001_create_siem.sql"
  },
  "dependencies": {
    "@osiris/nats-client": "workspace:*",
    "@osiris/logger": "workspace:*",
    "@osiris/metrics": "workspace:*",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/joi": "^17.2.3",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  }
}