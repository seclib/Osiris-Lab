{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Notification Delivered Event",
  "description": "Event published when a notification has been delivered to the user",
  "type": "object",
  "required": ["notificationId", "userId", "channel", "deliveredAt"],
  "properties": {
    "notificationId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique notification identifier"
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "User who received the notification"
    },
    "channel": {
      "type": "string",
      "enum": ["websocket", "push", "email"],
      "description": "Channel used to deliver the notification"
    },
    "deliveredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when notification was delivered"
    },
    "deviceInfo": {
      "type": "object",
      "description": "Device information (for push notifications)"
    },
    "metadata": {
      "type": "object",
      "description": "Additional delivery metadata"
    }
  }
}