{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkflowCreatedEvent",
  "description": "Published when a new workflow is created",
  "type": "object",
  "required": ["id", "type", "source", "timestamp", "version", "payload"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["workflow.created"] },
    "source": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version": { "type": "string" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "required": ["workflow_id", "name", "dag"],
      "properties": {
        "workflow_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "dag": {
          "type": "object",
          "required": ["nodes", "edges"],
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "type", "name"],
                "properties": {
                  "id": { "type": "string" },
                  "type": { "type": "string" },
                  "name": { "type": "string" },
                  "config": { "type": "object" }
                }
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["from", "to"],
                "properties": {
                  "from": { "type": "string" },
                  "to": { "type": "string" },
                  "condition": { "type": "string" }
                }
              }
            }
          }
        },
        "created_by": { "type": "string", "format": "uuid" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "user_id": { "type": "string" }
      }
    }
  }
}