{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow Execution Started Event",
  "description": "Event published when a workflow execution has started",
  "type": "object",
  "required": ["executionId", "workflowId", "workflowName", "startedAt", "triggeredBy"],
  "properties": {
    "executionId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique execution identifier"
    },
    "workflowId": {
      "type": "string",
      "format": "uuid",
      "description": "Workflow definition identifier"
    },
    "workflowName": {
      "type": "string",
      "description": "Human-readable workflow name"
    },
    "workflowVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "Workflow version number"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when execution started"
    },
    "triggeredBy": {
      "type": "string",
      "enum": ["manual", "scheduled", "event"],
      "description": "What triggered the workflow"
    },
    "triggeredByUserId": {
      "type": "string",
      "format": "uuid",
      "description": "User who triggered (if manual)"
    },
    "input": {
      "type": "object",
      "description": "Workflow input parameters"
    },
    "dag": {
      "type": "object",
      "description": "DAG structure (nodes and edges)"
    }
  }
}