{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkflowUpdatedEvent",
  "description": "Published when a workflow is updated",
  "type": "object",
  "required": ["id", "type", "source", "timestamp", "version", "payload"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["workflow.updated"] },
    "source": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version": { "type": "string" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "causation_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "required": ["workflow_id", "version", "changes"],
      "properties": {
        "workflow_id": { "type": "string", "format": "uuid" },
        "version": { "type": "integer", "minimum": 1 },
        "changes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dag": {
          "type": "object",
          "properties": {
            "nodes": { "type": "array" },
            "edges": { "type": "array" }
          }
        },
        "updated_by": { "type": "string", "format": "uuid" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "user_id": { "type": "string" }
      }
    }
  }
}