{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkflowDeletedEvent",
  "description": "Published when a workflow is deleted",
  "type": "object",
  "required": ["id", "type", "source", "timestamp", "version", "payload"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "enum": ["workflow.deleted"] },
    "source": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version": { "type": "string" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "required": ["workflow_id"],
      "properties": {
        "workflow_id": { "type": "string", "format": "uuid" },
        "deleted_by": { "type": "string", "format": "uuid" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "user_id": { "type": "string" }
      }
    }
  }
}